extern fn ZString libbpf_bpf_prog_type_str(BpfProgType t);

enum LibbpfPrintLevel
{
    LIBBPF_WARN,
    LIBBPF_INFO,
    LIBBPF_DEBUG,
}


// TODO: requires va_list support
alias VaList = void;
alias LibbpfPrintFnT = fn int(LibbpfPrintLevel level, ZString fmt, VaList* ap);
extern fn LibbpfPrintFnT libbpf_set_print(LibbpfPrintFnT cb);

struct BpfObjectOpenOpts
{
    usz size;
    ZString object_name;
    bool relaxed_maps;
    ZString pin_root_path;
    uint __u32;
    ZString kconfig;
    ZString btf_custom_path;
    ZString kernel_log_buf;
    usz kernel_log_size;
    uint kernel_log_level;
    ZString bpf_token_path;
}

extern fn BpfObject* bpf_object__open(ZString path);
extern fn BpfObject* bpf_object__open_file(ZString path, BpfObjectOpenOpts opts);

extern fn BpfObject* bpf_object__open_mem(void* obj_buf, usz obj_buf_sz, BpfObjectOpenOpts* opts);
extern fn int bpf_object__prepare(BpfObject* obj);
extern fn int bpf_object__load(BpfObject* obj);
extern fn void bpf_object__close(BpfObject* obj);
extern fn int bpf_object__pin_maps(BpfObject* obj, ZString path);
extern fn int bpf_object__unpin_maps(BpfObject* obj, ZString path);
extern fn int bpf_object__pin_programs(BpfObject* obj, ZString path);
extern fn int bpf_object__unpin_programs(BpfObject* obj, ZString path);
extern fn int bpf_object__pin(BpfObject* object, ZString path);
extern fn int bpf_object__unpin(BpfObject* object, ZString path);

extern fn ZString bpf_object__name(BpfObject* obj);
extern fn uint bpf_object__kversion(BpfObject* obj);
extern fn int bpf_object__set_kversion(BpfObject* obj, uint kern_version);

extern fn int bpf_object__token_fd(BpfObject* obj);
extern fn Btf* bpf_object__btf(BpfObject* obj);
extern fn int bpf_object__btf_fd(BpfObject* obj);

extern fn BpfProgram* bpf_object__find_program_by_name(BpfObject* obj, ZString name);
