struct BpfMapSkeleton
{
    ZString name;
    BpfMap** map;
    void** mmaped;
    BpfLink** link;
}
struct BpfProgSkeleton
{
    ZString name;
    BpfProgram** prog;
    BpfLink** link;
}
struct BpfObjectSkeleton
{
    usz size;
    ZString name;
    void* data;
    usz data_sz;
    BpfObject** obj;
    int map_cnt;
    int map_skel_sz;
    BpfMapSkeleton* maps;
    int prog_cnt;
    int prog_skel_sz;
    BpfProgSkeleton* progs;
}
