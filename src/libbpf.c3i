    ZString kernel_log_buf;
    usz kernel_log_size;
    uint kernel_log_level;
    ZString bpf_token_path;
}

struct BpfInsn
{
    char code;
    // Original C:
    // __u8 dst_reg:4;
    // __u8 src_reg:4;
    // 
    // Lower 4 bits: destination register
    // Upper 4 bits: source register
    char regs;
    short off;
    int imm;
}

macro uint dst_reg(BpfInsn* insn)
{
    return insn.regs & 0x0F;
}

macro uint src_reg(BpfInsn* insn)
{
    return (insn.regs >> 4) & 0x0F;
}

