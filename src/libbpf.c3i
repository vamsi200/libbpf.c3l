    int prog_skel_sz;
    BpfProgSkeleton* progs;
    int var_cnt;
    int var_skel_sz;
    BpfVarSkeleton* vars;
}
extern fn int bpf_object__open_subskeleton(BpfObjectSubskeleton* s);
extern fn void bpf_object__destroy_subskeleton(BpfObjectSubskeleton* s);

// Gen loader

struct GenLoaderOpts
{
    usz size;
    ZString data;
    ZString insns;
    uint data_sz;
    uint insns_sz;
    bool gen_hash;
}
extern fn int bpf_object__gen_loader(BpfObject* obj, GenLoaderOpts* opts);

// Linker

typedef BpfLinker = void;

struct BpfLinkerOpts
{
    usz size;
}
struct BpfLinkerFileOpts
{
    usz size;
}
extern fn BpfLinker* bpf_linker__new(ZString filename, BpfLinkerOpts* opts);
extern fn BpfLinker* bpf_linker__new_fd(int fd, BpfLinkerOpts* opts);
extern fn int bpf_linker__add_file(BpfLinker* linker, ZString filename, BpfLinkerFileOpts* opts);
extern fn int bpf_linker__add_fd(BpfLinker* linker, int fd, BpfLinkerFileOpts* opts);
extern fn int bpf_linker__add_buf(
    BpfLinker* linker,
    void* buf,
    usz buf_sz,
    BpfLinkerFileOpts* opts
);
extern fn int bpf_linker__finalize(BpfLinker* linker);
extern fn void bpf_linker__free(BpfLinker* linker);

// Custom prog handler

alias Libbpf_Prog_Setup_Fn_T = fn int(BpfProgram* prog, long cookie);
alias Libbpf_Prog_Prepare_Load_Fn_T = fn int(BpfProgram* prog, BpfProgLoadOpts* opts, long cookie);
alias Libbpf_Prog_Attach_Fn_T = fn int(BpfProgram* prog, long cookie, BpfLink** link);

struct LibbpfProgHandlerOpts
{
    usz size;
    long cookie;
    Libbpf_Prog_Setup_Fn_T prog_setup_fn;
    Libbpf_Prog_Prepare_Load_Fn_T prog_prepare_load_fn;
    Libbpf_Prog_Attach_Fn_T prog_attach_fn;
}
extern fn int libbpf_register_prog_handler(
    ZString sec,
    BpfProgType prog_type,
    BpfAttachType exp_attach_type,
    LibbpfProgHandlerOpts* opts
);
extern fn int libbpf_unregister_prog_handler(int handler_id);
